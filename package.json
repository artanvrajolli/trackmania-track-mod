{
  "name": "trackmania-map-viewer",
  "version": "1.0.1",
  "description": "Trackmania Exchange Map Viewer",
  "author": "artanvrajolli",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "track:clean": "node scripts/track-clean.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.trackmania.mapviewer",
    "productName": "Trackmania Map Viewer",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "background.jpg"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": null
  },
  "dependencies": {
    "electron-store": "^7.0.3"
  }
}
